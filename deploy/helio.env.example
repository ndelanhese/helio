# Copy to helio.env for local, non-secret runtime overrides.
# Keep logger addresses, serial numbers, locations, and credentials out of Git.
#
# Compose publishes to 127.0.0.1 by default. HELIO_BIND_IP is Compose
# interpolation and is not read from this service env file. For phone access,
# set it in the shell or a project-level .env to this host's RFC1918 LAN
# interface address only. Never use 0.0.0.0 or a public interface address.
# HELIO_BIND_IP=<RFC1918-LAN-interface-IP>
HELIO_HTTP_ADDR=:8080
HELIO_DATABASE_PATH=/data/helio.db
HELIO_SECURE_COOKIES=0
HELIO_ALLOW_NON_PRIVATE_LOGGER=0
# Required only for encrypted optional cloud integrations. Generate once with:
# openssl rand -base64 32
# Keep this value outside Git and backups. Losing it means re-entering cloud credentials.
# HELIO_SECRETS_KEY=<base64-32-byte-key>
